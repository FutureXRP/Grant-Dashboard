# Copy to .env.local and fill in.

# Required for the AI agents (NOFO analyzer, drafter, red-team, compliance check).
# Get a key at https://platform.claude.com — without it, everything else still works.
ANTHROPIC_API_KEY=

# Optional: override the model (default: claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# Optional: durable cloud storage for uploaded documents via Supabase Storage.
# When both are set, uploads go to a private bucket (auto-created) instead of
# the local data/uploads/ folder. Get these from your Supabase project:
# Settings -> API -> Project URL, and Settings -> API -> service_role key.
# The service_role key bypasses security rules — server-side only, never share it.
# SUPABASE_URL=https://yourproject.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_BUCKET=grant-documents
